# ================================
# Agent Task Analyzer - 設定檔
# ================================
# 複製此檔案為 .env 並填入你的設定

# [必填] Anthropic API Key
# 取得方式：https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-...

# [選填] 伺服器 Port（預設 3000）
PORT=3000

# [選填] 資料庫路徑（預設 ./data/tasks.db）
DB_PATH=./data/tasks.db

# [選填] 任務拆解時使用的 Claude 模型
# 推薦：claude-sonnet-4-6（速度/品質平衡）
MODEL=claude-sonnet-4-6
